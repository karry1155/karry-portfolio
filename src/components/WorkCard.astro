---
export interface Props {
  slug: string;
  title: string;
  category: string;
  cover: string;
  date: string;
  tags?: string[];
}
const { slug, title, category, cover, date, tags = [] } = Astro.props;

const categoryLabel = category === 'graphic-design' ? 'Graphic Design' : 'AI Video';
const categoryColor = category === 'ai-video' ? 'text-purple-400' : 'text-accent';
---
<a href={`/works/${slug}`} class="group block">
  <div class="relative overflow-hidden rounded-sm bg-surface border border-border aspect-[4/3]">
    <img
      src={cover}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
  </div>
  <div class="mt-3 space-y-1">
    <div class="flex items-center justify-between">
      <span class={`text-xs font-mono uppercase tracking-wider ${categoryColor}`}>{categoryLabel}</span>
      <span class="text-xs text-muted font-mono">{date}</span>
    </div>
    <h3 class="text-sm font-medium text-white group-hover:text-accent transition-colors">{title}</h3>
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 pt-0.5">
        {tags.map(tag => (
          <span class="text-xs text-muted bg-surface border border-border px-2 py-0.5 rounded-sm">
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
</a>
