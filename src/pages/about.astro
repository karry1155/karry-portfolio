---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About">
  <section class="max-w-2xl mx-auto px-6 py-24">
    <p class="font-mono text-xs text-muted uppercase tracking-widest mb-8">About</p>

    <h1 class="text-3xl font-light text-white mb-8">Karry Shi</h1>

    <div class="space-y-5 text-zinc-400 leading-relaxed text-base">
      <p>
        Designer and AI video creator based in China. Working at the intersection of
        visual communication and generative media.
      </p>
      <p>
        This portfolio is updated directly from Obsidian — each project is a note,
        published automatically via GitHub and Cloudflare Pages.
      </p>
      <p>
        Currently exploring AI-generated video workflows, brand identity systems,
        and motion design.
      </p>
    </div>

    <div class="mt-16 pt-8 border-t border-border">
      <p class="text-sm text-muted font-mono mb-4">Contact</p>
      <a href="mailto:shikairui11@gmail.com" class="text-accent hover:underline font-mono text-sm">
        shikairui11@gmail.com
      </a>
    </div>
  </section>
</BaseLayout>
