---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const works = await getCollection('works');
  return works.map(work => ({
    params: { slug: work.slug },
    props: { work },
  }));
}

const { work } = Astro.props;
const { Content } = await work.render();

const categoryMeta = {
  'graphic-design': { label: 'Graphic Design', color: 'text-accent' },
  'ai-video': { label: 'AI Video', color: 'text-purple-400' },
  website: { label: 'Website', color: 'text-sky-400' },
};
const categoryLabel = categoryMeta[work.data.category]?.label ?? work.data.category;
const categoryColor = categoryMeta[work.data.category]?.color ?? 'text-accent';
---
<BaseLayout title={work.data.title} description={work.data.title + ' — Karry Portfolio'}>
  <article class="max-w-4xl mx-auto px-6 py-16">

    <!-- Back -->
    <a href="/" class="inline-flex items-center gap-2 text-sm text-muted hover:text-white transition-colors mb-12 font-mono">
      ← Back
    </a>

    <!-- Meta -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-3">
        <span class={`text-xs font-mono uppercase tracking-widest ${categoryColor}`}>{categoryLabel}</span>
        <span class="text-muted text-xs">·</span>
        <span class="text-xs font-mono text-muted">{work.data.date}</span>
      </div>
      <h1 class="text-3xl font-light text-white mb-4">{work.data.title}</h1>
      {work.data.tags && (
        <div class="flex flex-wrap gap-2">
          {work.data.tags.map(tag => (
            <span class="text-xs text-muted bg-surface border border-border px-2.5 py-1 rounded-sm font-mono">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>

    <!-- Cover -->
    <div class="rounded-sm overflow-hidden border border-border mb-12">
      <img src={work.data.cover} alt={work.data.title} class="w-full object-cover" />
    </div>

    <!-- Video embed (YouTube iframe or local mp4) -->
    {work.data.video && work.data.video.startsWith('http') && (
      <div class="mb-12 rounded-sm overflow-hidden border border-border aspect-video bg-surface">
        <iframe
          src={work.data.video}
          class="w-full h-full"
          frameborder="0"
          allow="autoplay; fullscreen; picture-in-picture"
          allowfullscreen
        />
      </div>
    )}
    {work.data.video && !work.data.video.startsWith('http') && (
      <div class="mb-12 rounded-sm overflow-hidden border border-border bg-surface">
        <video
          src={work.data.video}
          autoplay
          loop
          muted
          playsinline
          controls
          class="w-full"
        />
      </div>
    )}

    <!-- Content -->
    <div class="work-content max-w-none">
      <Content />
    </div>

  </article>
</BaseLayout>

<style>
  .work-content {
    color: #a1a1aa;
    font-size: 1rem;
    line-height: 1.8;
  }

  .work-content :global(p) {
    margin: 0 0 1.25rem;
  }

  .work-content :global(h2) {
    margin: 2.5rem 0 1rem;
    padding-bottom: 0.55rem;
    border-bottom: 1px solid #222;
    color: #fff;
    font-size: 1.35rem;
    font-weight: 500;
    line-height: 1.35;
  }

  .work-content :global(h3) {
    margin: 2rem 0 0.8rem;
    color: #e8ff47;
    font-size: 1.05rem;
    font-weight: 500;
    line-height: 1.4;
  }

  .work-content :global(ul),
  .work-content :global(ol) {
    margin: 0 0 1.4rem 1.2rem;
    padding-left: 1rem;
  }

  .work-content :global(ul) {
    list-style: disc;
  }

  .work-content :global(ol) {
    list-style: decimal;
  }

  .work-content :global(li) {
    margin: 0.35rem 0;
    padding-left: 0.2rem;
  }

  .work-content :global(a) {
    color: #e8ff47;
    text-decoration: none;
  }

  .work-content :global(a:hover) {
    text-decoration: underline;
  }

  .work-content :global(pre) {
    margin: 1rem 0 1.4rem;
    padding: 1rem;
    border: 1px solid #222;
    border-radius: 4px;
    background: #111 !important;
    overflow-x: auto;
    white-space: pre-wrap;
  }

  .work-content :global(code) {
    color: #e4e4e7;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.9rem;
  }

  .work-content :global(img) {
    border: 1px solid #222;
    border-radius: 4px;
  }
</style>
